{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique firebase authentication user id",
          "pattern": "^[a-zA-Z0-9_\\-]+$"
        },
        "email": {
          "type": "string",
          "description": "User email address"
        },
        "displayName": {
          "type": "string",
          "description": "Display name of the user",
          "maxLength": 100
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the user was created"
        }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Note": {
      "title": "Note",
      "description": "A synchronized personal markdown note",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The custom note document ID",
          "pattern": "^[a-zA-Z0-9_\\-]+$"
        },
        "userId": {
          "type": "string",
          "description": "Owner userId of this note",
          "pattern": "^[a-zA-Z0-9_\\-]+$"
        },
        "title": {
          "type": "string",
          "description": "Title of the note",
          "minLength": 1,
          "maxLength": 200
        },
        "content": {
          "type": "string",
          "description": "Markdown content of the note",
          "maxLength": 50000
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the note was first created"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the note was last updated"
        }
      },
      "required": ["id", "userId", "title", "content", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user records"
    },
    "/users/{userId}/notes/{noteId}": {
      "schema": "Note",
      "description": "User specific list of personal notes"
    }
  }
}
